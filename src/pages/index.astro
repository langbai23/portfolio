---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/portfolio/NavBar.astro";
import HeroSection from "../components/portfolio/HeroSection.astro";
import ProjectsSection from "../components/portfolio/ProjectsSection.astro";
import AboutSection from "../components/portfolio/AboutSection.astro";
import ContactSection from "../components/portfolio/ContactSection.astro";
import SiteFooter from "../components/portfolio/SiteFooter.astro";
import LanguageScript from "../components/portfolio/LanguageScript.astro";
---

<Layout
  title="David Bao | Game Design Portfolio"
  description="David Bao's bilingual game design portfolio built with Astro."
  ogImage="/about-photo.png"
>
  <NavBar />

  <main class="container">
    <HeroSection />
    <ProjectsSection />
    <AboutSection />
    <ContactSection />
  </main>

  <SiteFooter />
  <LanguageScript />
</Layout>