---
import ProjectCard from "./ProjectCard.astro";
import { HOME_PROJECTS } from "../../data/projects";

const [featured, ...rest] = HOME_PROJECTS;
---

<section id="projects">
  <span class="section-eyebrow" data-i18n="projectsEyebrow">Selected Work</span>
  <h2 class="section-title" data-i18n="projectsTitle">Projects</h2>
  <p class="section-subtitle" data-i18n="projectsSubtitle">
    Latest work first. Each project opens a case study with my role, process, and footage.
  </p>

  <div class="project-grid">
    {featured && <ProjectCard project={featured} featured />}
    {rest.map((project) => <ProjectCard project={project} />)}
  </div>

  <div class="projects-view-all">
    <a href="/projects/all" class="button" data-i18n="viewAllProjects">View all projects</a>
  </div>
</section>
