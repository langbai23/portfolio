  const langButtons = document.querySelectorAll("[data-lang]");
  const i18nNodes = document.querySelectorAll("[data-i18n]");

  const setLanguage = (lang) => {
    i18nNodes.forEach((node) => {
      const key = node.getAttribute("data-i18n");
      if (key && translations[lang][key]) {
        node.textContent = translations[lang][key];
      }
    });

    document.querySelectorAll("[data-i18n-alt]").forEach((node) => {
      const key = node.getAttribute("data-i18n-alt");
      if (key && translations[lang][key]) {
        node.setAttribute("alt", translations[lang][key]);
      }
    });

    document.documentElement.setAttribute("lang", lang === "zh" ? "zh-CN" : "en");

    langButtons.forEach((button) => {
      button.classList.toggle("active", button.getAttribute("data-lang") === lang);
    });
  };

  langButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const lang = button.getAttribute("data-lang");
      if (lang) setLanguage(lang);
    });
  });

  setLanguage("en");

  // Home links use /#projects, /#about, etc. The hash stays in the URL, so refresh jumps to that section.
  // On full reload only, strip the hash and scroll to the top so refresh returns to the hero.
  window.addEventListener("pageshow", () => {
    const nav = performance.getEntriesByType("navigation")[0];
    const isReload =
      (nav && nav.type === "reload") ||
      (typeof performance.navigation !== "undefined" && performance.navigation.type === 1);
    if (!isReload || !window.location.hash) return;
    const path = window.location.pathname;
    if (path !== "/" && !path.endsWith("/index.html")) return;
    history.replaceState(null, "", `${path}${window.location.search}`);
    window.scrollTo(0, 0);
  });

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const revealItems = document.querySelectorAll(".reveal-item");

  if (prefersReducedMotion) {
    revealItems.forEach((item) => item.classList.add("is-visible"));
  } else {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: "0px 0px -20px 0px" }
    );

    revealItems.forEach((item) => revealObserver.observe(item));
  }

  const canHoverPreview = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
  const previewMediaNodes = document.querySelectorAll("[data-preview-video-id]");

  previewMediaNodes.forEach((mediaNode) => {
    const slot = mediaNode.querySelector("[data-preview-slot]");
    const videoId = mediaNode.getAttribute("data-preview-video-id");
    const videoTitle = mediaNode.getAttribute("data-preview-title") || "Project preview";
    const previewMode = mediaNode.getAttribute("data-preview-mode") || "autoplay";
    const previewStart = mediaNode.getAttribute("data-preview-start");
    const previewEnd = mediaNode.getAttribute("data-preview-end");
    const previewSegments = mediaNode.getAttribute("data-preview-segments");
    let iframe = null;
    let segmentTimerId = null;
    let repeatTimerId = null;
    let currentSegmentIndex = 0;

    if (!slot || !videoId) return;

    const segments = previewSegments
      ? previewSegments
          .split(",")
          .map((rawSegment) => rawSegment.trim())
          .map((segment) => {
            const [startRaw, endRaw] = segment.split("-");
            const start = Number(startRaw);
            const end = Number(endRaw);
            return Number.isFinite(start) && Number.isFinite(end) && end > start
              ? { start, end }
              : null;
          })
          .filter(Boolean)
      : [];

    const buildIframeSrc = (startValue, endValue) => {
      const params = new URLSearchParams({
        autoplay: "1",
        mute: "1",
        controls: "0",
        modestbranding: "1",
        rel: "0",
        playsinline: "1"
      });

      const hasClipBounds =
        typeof startValue === "number" &&
        typeof endValue === "number" &&
        Number.isFinite(startValue) &&
        Number.isFinite(endValue);

      if (typeof startValue === "number" && Number.isFinite(startValue)) {
        params.set("start", String(Math.floor(startValue)));
      }
      if (typeof endValue === "number" && Number.isFinite(endValue)) {
        params.set("end", String(Math.ceil(endValue)));
      }

      if (!hasClipBounds) {
        params.set("loop", "1");
        params.set("playlist", videoId);
      }

      return `https://www.youtube.com/embed/${videoId}?${params.toString()}`;
    };

    const renderIframe = (startValue, endValue) => {
      if (iframe) {
        iframe.remove();
        iframe = null;
      }

      iframe = document.createElement("iframe");
      iframe.src = buildIframeSrc(startValue, endValue);
      iframe.title = videoTitle;
      iframe.loading = "lazy";
      iframe.allow = "autoplay; encrypted-media; picture-in-picture";
      iframe.referrerPolicy = "strict-origin-when-cross-origin";
      slot.appendChild(iframe);
      mediaNode.classList.add("is-playing");
    };

    const clearTimers = () => {
      if (segmentTimerId) {
        window.clearTimeout(segmentTimerId);
        segmentTimerId = null;
      }
      if (repeatTimerId) {
        window.clearTimeout(repeatTimerId);
        repeatTimerId = null;
      }
    };

    const playSingleClip = () => {
      const singleStart = previewStart ? Number(previewStart) : NaN;
      const singleEnd = previewEnd ? Number(previewEnd) : NaN;

      if (Number.isFinite(singleStart) && Number.isFinite(singleEnd)) {
        renderIframe(singleStart, singleEnd);
        repeatTimerId = window.setTimeout(() => {
          repeatTimerId = null;
          playSingleClip();
        }, Math.max(800, (singleEnd - singleStart) * 1000));
        return;
      }

      renderIframe(
        Number.isFinite(singleStart) ? singleStart : undefined,
        Number.isFinite(singleEnd) ? singleEnd : undefined
      );
    };

    const playCurrentSegment = () => {
      if (!segments.length) {
        playSingleClip();
        return;
      }

      const currentSegment = segments[currentSegmentIndex];
      renderIframe(currentSegment.start, currentSegment.end);

      const segmentDurationMs = Math.max(800, (currentSegment.end - currentSegment.start) * 1000);
      segmentTimerId = window.setTimeout(() => {
        segmentTimerId = null;
        currentSegmentIndex = (currentSegmentIndex + 1) % segments.length;
        playCurrentSegment();
      }, segmentDurationMs);
    };

    const startPreview = () => {
      if (iframe || segmentTimerId || repeatTimerId) return;
      currentSegmentIndex = 0;
      playCurrentSegment();
    };

    const stopPreview = () => {
      clearTimers();
      if (iframe) {
        iframe.remove();
        iframe = null;
      }
      mediaNode.classList.remove("is-playing");
    };

    if (previewMode === "hover") {
      if (!canHoverPreview) return;
      mediaNode.addEventListener("mouseenter", startPreview);
      mediaNode.addEventListener("mouseleave", stopPreview);
      mediaNode.addEventListener("focusin", startPreview);
      mediaNode.addEventListener("focusout", stopPreview);
      return;
    }

    const previewObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            startPreview();
          } else {
            stopPreview();
          }
        });
      },
      { threshold: 0.35, rootMargin: "0px 0px -10% 0px" }
    );

    previewObserver.observe(mediaNode);
  });
</script>
