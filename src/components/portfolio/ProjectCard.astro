---
import type { ProjectEntry } from "../../data/projects";
import T from "../T.astro";

interface Props {
  project: ProjectEntry;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
const detailHref = `/projects/${project.id}`;
const yt = project.youtubeId;
---

<article class:list={["project-card", "reveal-item", { featured }]}>
  {
    yt ? (
      <button
        class="project-media yt-facade"
        type="button"
        data-youtube-id={yt}
        data-youtube-title={`${project.title} — gameplay video`}
        aria-label={`Play ${project.title} video`}
      >
        <img src={project.cover} alt="" loading="lazy" decoding="async" width="1280" height="720" />
        <span class="yt-play-btn" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
      </button>
    ) : (
      <a class="project-media project-media-link" href={detailHref}>
        <img src={project.cover} alt="" loading="lazy" decoding="async" width="1280" height="720" />
      </a>
    )
  }

  <div class="project-content">
    <div class="project-meta">
      <span class="project-meta-left">
        {featured && <span class="featured-label" data-i18n="featuredLabel">Latest</span>}
        <T t={project.status} class="status-pill" />
      </span>
      <span class="project-year">{project.year}</span>
    </div>
    <T t={project.tag} class="project-tag" />
    <h3><a href={detailHref}>{project.title}</a></h3>
    <T t={project.summary} as="p" class="project-summary" />
    <div class="project-card-footer">
      <div class="meta-chips">
        {project.chips.map((chip) => <T t={chip} class="meta-chip" />)}
      </div>
      <a class="card-cta" href={detailHref} data-i18n="caseStudyCta">Read case study</a>
    </div>
  </div>
</article>
