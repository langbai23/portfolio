---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const resolvedOgImage = ogImage
  ? Astro.site
    ? new URL(ogImage, Astro.site).toString()
    : ogImage
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <meta name="twitter:card" content={resolvedOgImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #0a0f24;
    --card: #11182f;
    --text: #eef2ff;
    --muted: #9aa7c7;
    --accent: #7c6cff;
    --accent-2: #4f8dff;
    --border: rgba(170, 190, 255, 0.1);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: Arial, sans-serif;
    background:
      radial-gradient(circle at 12% 8%, rgba(124, 108, 255, 0.26), transparent 34%),
      radial-gradient(circle at 88% 4%, rgba(79, 141, 255, 0.18), transparent 30%),
      radial-gradient(circle at 50% 100%, rgba(99, 102, 241, 0.12), transparent 42%),
      var(--bg);
    color: var(--text);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: min(1100px, calc(100% - 48px));
    margin: 0 auto;
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  nav {
    position: sticky;
    top: 0;
    backdrop-filter: blur(12px);
    background: rgba(10, 15, 36, 0.82);
    border-bottom: 1px solid var(--border);
    z-index: 10;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: bold;
    letter-spacing: 0.04em;
  }

  .nav-links {
    display: flex;
    gap: 20px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .lang-switch {
    display: flex;
    gap: 8px;
  }

  .lang-btn {
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-size: 0.85rem;
    transition: 0.2s ease;
  }

  .lang-btn.active {
    color: var(--text);
    border-color: rgba(124, 108, 255, 0.5);
    background: rgba(124, 108, 255, 0.16);
  }

  .lang-btn:hover {
    color: var(--text);
  }

  .hero {
    min-height: 85vh;
    display: grid;
    align-items: center;
    padding: 72px 0 40px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: center;
  }

  .eyebrow {
    display: inline-block;
    color: var(--accent);
    font-size: 0.95rem;
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin-bottom: 18px;
  }

  .hero .hero-tagline {
    font-size: 0.98rem;
    color: var(--muted);
    max-width: 580px;
    margin-top: -6px;
    margin-bottom: 10px;
    line-height: 1.45;
  }

  .hero .hero-intro {
    font-size: 1.02rem;
    color: var(--muted);
    max-width: 580px;
    margin-bottom: 14px;
    line-height: 1.55;
  }

  .hero-skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    margin: 0 0 22px;
    padding: 0;
    max-width: 580px;
  }

  .pill-tag {
    display: inline-flex;
    align-items: center;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #d7dced;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(140, 165, 220, 0.35);
    transition:
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      background 0.22s ease;
  }

  .pill-tag:hover {
    border-color: rgba(124, 108, 255, 0.75);
    box-shadow:
      0 0 0 1px rgba(124, 108, 255, 0.25),
      0 0 18px rgba(124, 108, 255, 0.28);
    background: rgba(124, 108, 255, 0.08);
  }

  .button-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .button {
    padding: 12px 20px;
    border-radius: 999px;
    border: 1px solid var(--border);
    display: inline-block;
    font-weight: bold;
    transition: 0.2s ease;
  }

  .button.primary {
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
    border: none;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .hero-card {
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.25);
  }

  .hero-card h3 {
    margin-bottom: 12px;
    font-size: 1.1rem;
  }

  .hero-card p {
    margin-bottom: 0;
    font-size: 0.98rem;
  }

  section {
    padding: 84px 0;
  }

  .section-title {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .section-eyebrow {
    display: inline-block;
    margin-bottom: 10px;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .section-subtitle {
    color: var(--muted);
    max-width: 680px;
    margin-bottom: 28px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    align-items: stretch;
  }

  .project-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: 24px;
    transition: transform 0.2s ease, border-color 0.2s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .project-media {
    position: relative;
    margin: -6px -6px 16px;
    padding: 0;
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .project-media::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(2, 6, 23, 0.06) 0%, rgba(2, 6, 23, 0.34) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .project-media::after {
    content: "";
    position: absolute;
    inset: 0;
    box-shadow: inset 0 -40px 60px rgba(2, 6, 23, 0.42);
    z-index: 2;
    pointer-events: none;
  }

  .project-media-link {
    display: block;
  }

  .project-media-link:focus-visible {
    outline: 2px solid rgba(124, 108, 255, 0.7);
    outline-offset: 3px;
  }

  .project-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    margin-bottom: 0;
    transition: opacity 0.25s ease, transform 0.3s ease;
  }

  .project-card:hover img {
    transform: scale(1.035);
  }

  .project-card:hover {
    transform: translateY(-3px);
    border-color: rgba(124, 108, 255, 0.45);
  }

  .project-media .preview-slot {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    overflow: hidden;
    pointer-events: none;
  }

  .project-media .preview-slot iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .project-media.is-playing .preview-poster {
    opacity: 0;
  }

  .preview-hint {
    position: absolute;
    right: 14px;
    bottom: 14px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: #eef2ff;
    background: rgba(15, 23, 42, 0.68);
    border: 1px solid rgba(255, 255, 255, 0.16);
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .project-media.is-playing .preview-hint {
    opacity: 0;
  }

  .project-content {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .project-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid rgba(124, 108, 255, 0.35);
    color: #d7c8ff;
    background: rgba(124, 108, 255, 0.12);
  }

  .project-year {
    font-size: 0.82rem;
    color: var(--muted);
  }

  .project-tag {
    display: inline-block;
    font-size: 0.82rem;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .project-card h3 {
    margin-bottom: 8px;
    font-size: 1.25rem;
  }

  .project-card p {
    color: var(--muted);
    margin-bottom: 12px;
  }

  .tools {
    font-size: 0.92rem;
    color: #d5dbeb;
    margin-bottom: 12px;
  }

  .meta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    color: #d7dced;
    font-size: 0.75rem;
  }

  .reveal-item {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .about-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 28px;
    transition:
      border-color 0.22s ease,
      box-shadow 0.22s ease;
  }

  .about-box:hover {
    border-color: rgba(124, 108, 255, 0.4);
    box-shadow: 0 0 28px rgba(124, 108, 255, 0.12);
  }

  .about-layout {
    display: grid;
    grid-template-columns: minmax(200px, 280px) minmax(0, 1fr);
    gap: 28px;
    align-items: start;
  }

  .about-main {
    min-width: 0;
  }

  .about-photo-wrap {
    margin: 0;
  }

  .about-photo {
    width: 100%;
    max-width: 280px;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: block;
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.35);
  }

  .about-copy p {
    color: var(--muted);
    max-width: 720px;
    margin-bottom: 1em;
    line-height: 1.65;
  }

  .about-copy p:last-child {
    margin-bottom: 0;
  }

  .stats-grid {
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }

  .stat-card {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    border-radius: 14px;
    padding: 14px 12px;
    transition:
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      background 0.22s ease;
  }

  .stat-card:hover {
    border-color: rgba(124, 108, 255, 0.55);
    box-shadow:
      0 0 0 1px rgba(124, 108, 255, 0.15),
      0 0 20px rgba(124, 108, 255, 0.22);
    background: rgba(124, 108, 255, 0.06);
  }

  .stat-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: #e6ecff;
    line-height: 1.1;
  }

  .stat-label {
    margin-top: 6px;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .skills-title {
    margin-top: 20px;
    font-size: 0.92rem;
    color: #d7dced;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  .contact-box {
    text-align: center;
    background: linear-gradient(180deg, rgba(124, 108, 255, 0.14), rgba(79, 141, 255, 0.08));
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px 24px;
  }

  .contact-actions {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  footer {
    padding: 26px 0 40px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .project-detail {
    padding: 28px 0 88px;
  }

  .project-detail-back {
    margin-bottom: 14px;
  }

  .project-detail-back a {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .project-detail-back a:hover {
    color: var(--text);
  }

  .project-detail-lede {
    color: var(--muted);
    margin: 0 0 28px;
    max-width: 720px;
    line-height: 1.55;
  }

  .gallery-stack {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .gallery-figure {
    margin: 0;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card);
  }

  .gallery-figure img {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }

  .projects-view-all {
    display: flex;
    justify-content: center;
    margin-top: 8px;
    padding-bottom: 8px;
  }

  .projects-all-page {
    padding: 28px 0 72px;
  }

  .projects-all .section-title {
    margin-top: 8px;
  }

  @media (max-width: 960px) {
    .container {
      width: min(1100px, calc(100% - 32px));
    }

    section {
      padding: 68px 0;
    }
  }

  @media (max-width: 800px) {
    .hero-grid,
    .project-grid {
      grid-template-columns: 1fr;
    }

    .about-layout {
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .about-photo-wrap {
      justify-self: center;
      width: 100%;
      max-width: 280px;
    }

    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .nav-inner {
      flex-direction: column;
      gap: 14px;
      align-items: flex-start;
    }

    .nav-controls {
      width: 100%;
      justify-content: space-between;
      gap: 12px;
    }

    .nav-links {
      gap: 16px;
      font-size: 0.9rem;
      flex-wrap: wrap;
    }

    h1 {
      line-height: 1;
    }
  }

  @media (max-width: 560px) {
    .container {
      width: min(1100px, calc(100% - 24px));
    }

    .hero {
      min-height: auto;
      padding-top: 52px;
    }

    h1 {
      font-size: clamp(2.1rem, 12vw, 3.2rem);
      margin-bottom: 14px;
    }

    .hero .hero-tagline {
      font-size: 0.92rem;
      margin-bottom: 10px;
    }

    .hero .hero-intro {
      font-size: 0.95rem;
      margin-bottom: 12px;
    }

    .hero-skill-pills {
      margin-bottom: 18px;
    }

    .button-row {
      width: 100%;
    }

    .button {
      width: 100%;
      text-align: center;
    }

    .project-card,
    .about-box,
    .contact-box,
    .hero-card {
      border-radius: 18px;
      padding: 20px;
    }

    .section-title {
      font-size: 1.65rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .preview-hint {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    * {
      transition: none !important;
      animation: none !important;
    }

    .reveal-item {
      opacity: 1;
      transform: none;
    }
  }
</style>
